# ---- LLM (food/activity parsing) — Google Gemini, free tier ----
# Get a free key (no billing required) at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the model. gemini-1.5-flash is fast & free-tier friendly.
GEMINI_MODEL=gemini-1.5-flash

# ---- Strava OAuth (fill in when wiring the integration) ----
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# Public base URL (used to build OAuth redirects)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
